r mb-6\">\n                <ShieldCheck className=\"h-6 w-6 text-foreground\" />\n              </div>\n              <h3 className=\"text-lg font-semibold mb-2\">AI Detection</h3>\n              <p className=\"text-muted-foreground text-sm\">\n                Automatically classify issues from photos to ensure they reach the right department instantly.\n              </p>\n            </div>\n\n            <div className=\"flex flex-col items-center text-center p-6 border border-border rounded-xl bg-card\">\n              <div className=\"h-12 w-12 rounded-full bg-muted flex items-center justify-center mb-6\">\n                <FileText className=\"h-6 w-6 text-foreground\" />\n              </div>\n              <h3 className=\"text-lg font-semibold mb-2\">Smart Complaint Generation</h3>\n              <p className=\"text-muted-foreground text-sm\">\n                Our AI drafts professional reports, eliminating guesswork and speeding up processing times.\n              </p>\n            </div>\n\n            <div className=\"flex flex-col items-center text-center p-6 border border-border rounded-xl bg-card\">\n              <div className=\"h-12 w-12 rounded-full bg-muted flex items-center justify-center mb-6\">\n                <Zap className=\"h-6 w-6 text-foreground\" />\n              </div>\n              <h3 className=\"text-lg font-semibold mb-2\">Real-time Tracking</h3>\n              <p className=\"text-muted-foreground text-sm\">\n                Follow your report's status from submission to resolution with full transparency.\n              </p>\n            </div>\n          </div>\n        </div>\n      </section>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ritik\\OneDrive\\Desktop\\CIVICPULSE\\app\\report\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ritik\\OneDrive\\Des