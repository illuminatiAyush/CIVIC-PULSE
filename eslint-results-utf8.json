st { theme, setTheme } = useTheme();\n  const [mounted, setMounted] = useState(false);\n\n  useEffect(() => setMounted(true), []);\n\n  if (!mounted) {\n    return <div className=\"w-9 h-9\" />; // Placeholder to avoid layout shift\n  }\n\n  return (\n    <button\n      onClick={() => setTheme(theme === \"dark\" ? \"light\" : \"dark\")}\n      className=\"p-2 rounded-md hover:bg-muted transition-colors focus:outline-none focus:ring-2 focus:ring-ring\"\n      aria-label=\"Toggle theme\"\n    >\n      {theme === \"dark\" ? (\n        <Sun className=\"h-5 w-5 text-foreground\" />\n      ) : (\n        <Moon className=\"h-5 w-5 text-foreground\" />\n      )}\n    </button>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ritik\\OneDrive\\Desktop\\CIVICPULSE\\components\\UploadBox.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ritik\\OneDrive\\Desktop\\CIVICPULSE\\eslint.config.mjs","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ritik\\OneDrive\\Desktop\\CIVICPULSE\\lib\\supabaseClient.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ritik\\OneDrive\\Desktop\\CIVICPULSE\\next.config.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ritik\\OneDrive\\Desktop\\CIVICPULSE\\postcss.config.mjs","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ritik\\OneDrive\\Desktop\\CIVICPUL